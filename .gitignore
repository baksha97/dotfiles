*.py[cd]
.DS_Store
.idea/**
**/node_modules/**
# Local backups created by setup.sh before stowing
backup/

# Ignore everything under alacritty/.config/ except the actual alacritty config
stow/alacritty/.config/*
!stow/alacritty/.config/alacritty/
# Theme preview images serve no functional purpose (upstream repo documentation only)
stow/alacritty/.config/alacritty/themes/images/
!stow/alacritty/.config/linearmouse
!stow/alacritty/.config/git

# VS Code extensions are managed by VSCode itself, not dotfiles
stow/vscode/.vscode/extensions/

# Sublime Text packages with large binary/index files
sublime/Packages/

# Generated by setup.sh profile selection
stow/git/.gitconfig-profile

node_modules/

.claude/
