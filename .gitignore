*.py[cd]
.DS_Store
.idea/**
**/node_modules/**
# Local backups created by setup.sh before stowing
backup/

# Ignore everything under alacritty/.config/ except the actual alacritty config
stow/alacritty/.config/*
!stow/alacritty/.config/alacritty/
!stow/alacritty/.config/linearmouse
!stow/alacritty/.config/git

# VS Code internal tracking file (changes per machine)
stow/vscode/.vscode/extensions/.obsolete

# Generated by setup.sh profile selection
stow/git/.gitconfig-profile

node_modules/

.claude/
